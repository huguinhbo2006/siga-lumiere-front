{
    "name": "pedidos",
    "version": "0.0.0",
    "scripts": {
        "ng": "ng",
        "start": "ng serve --o",
        "build": "ng build",
        "watch": "ng build --watch --configuration development",
        "test": "ng test",
        "build:prod": "ng build -c production",
        "clean:compile": "del-cli \"compiler/**\" \"!compiler/.git\" \"!compiler/.gitignore\"",
        "copy:compile": "cpy \"dist/pedidos/browser/**/*\" compiler --parents",
        "build:compile": "npm run build:prod && npm run clean:compile && npm run copy:compile"
    },
    "private": true,
    "dependencies": {
        "@angular/animations": "^17.1.0",
        "@angular/cdk": "^17.3.3",
        "@angular/common": "^17.1.0",
        "@angular/compiler": "^17.1.0",
        "@angular/core": "^17.1.0",
        "@angular/forms": "^17.1.0",
        "@angular/material": "^17.3.3",
        "@angular/platform-browser": "^17.1.0",
        "@angular/platform-browser-dynamic": "^17.1.0",
        "@angular/router": "^17.1.0",
        "angular-images-resizer": "^2.0.3",
        "chart.js": "^4.4.9",
        "mammoth": "^1.11.0",
        "ngx-image-cropper": "^9.1.5",
        "papaparse": "^5.5.3",
        "pdfmake": "^0.2.20",
        "pdfmake-wrapper": "^2.1.3",
        "rxjs": "~7.8.0",
        "sweetalert2": "^11.10.7",
        "tesseract.js": "^6.0.1",
        "tslib": "^2.3.0",
        "zone.js": "~0.14.3"
    },
    "devDependencies": {
        "@angular-devkit/build-angular": "^17.1.3",
        "@angular/cli": "^17.1.3",
        "@angular/compiler-cli": "^17.1.0",
        "@types/jasmine": "~5.1.0",
        "@types/papaparse": "^5.5.2",
        "@types/pdfmake": "^0.2.11",
        "cpy-cli": "^7.0.0",
        "del-cli": "^7.0.0",
        "jasmine-core": "~5.1.0",
        "karma": "~6.4.0",
        "karma-chrome-launcher": "~3.2.0",
        "karma-coverage": "~2.2.0",
        "karma-jasmine": "~5.1.0",
        "karma-jasmine-html-reporter": "~2.1.0",
        "typescript": "~5.3.2"
    }
}
